{
  "name": "axia",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:landing": "turbo dev --filter=@axia/landing",
    "dev:bot": "turbo dev --filter=@axia/bot",
    "dev:portal": "turbo dev --filter=@axia/portal",
    "dev:convex": "npx convex dev",
    "prepare": "husky",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.19.17",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "turbo": "latest",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "convex": "^1.35.1"
  }
}
